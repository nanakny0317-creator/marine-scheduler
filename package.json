{
  "name": "marine-license-scheduler",
  "version": "0.1.0",
  "description": "船舶免許講習 受講者・申込管理システム",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "build:vite": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "date-fns": "^3.6.0",
    "exceljs": "^4.4.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.marine.scheduler",
    "productName": "船舶免許講習管理",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql.js/dist/sql-wasm.wasm"
      },
      {
        "from": "受領書式再現版.xlsx",
        "to": "受領書式再現版.xlsx"
      }
    ]
  }
}
